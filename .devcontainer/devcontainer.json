{
  "name": "Shaders-Complementary",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "workspaceMount": "source=${localWorkspaceFolder},target=/shaders,type=bind",
  "workspaceFolder": "/shaders",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mcgiver.mcshader",
        "ms-vscode.vscode-json",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "files.encoding": "utf8",
        "files.eol": "\n",
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "git.openRepositoryInParentFolders": "always",
        "git.autofetch": "all",
        "git.autoStash": true
      }
    }
  },
  "postCreateCommand": "echo 'Dev container ready for shader development'"
}
